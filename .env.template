# ===================================================================
# Variables de entorno - Sistema Académico Cayzedo (SAC)
# ===================================================================
# Renombre este archivo a `.env` y rellene los valores reales.
# El archivo `.env` NO se debe versionar.

# ============= PostgreSQL =============
# La aplicación usa PostgreSQL para todos los datos transaccionales.
# Postgres NO está en docker-compose: configúrelo aparte (instalación
# local, RDS, otro compose, etc.) y apunte estas variables ahí.
DB_HOST=localhost
DB_PORT=5432
DB_USER=calificaciones_user
DB_PASSWORD=changeme
DB_NAME=calificaciones_db
CALIFICACIONES_DB_SCHEMA=public

# ============= JWT =============
# La SecretKey debe tener al menos 32 caracteres. Genere una segura para producción.
JWT_ISSUER=sac-api
JWT_AUDIENCE=sac-clients
JWT_SECRET_KEY=CAMBIAR_ESTO_POR_UNA_CLAVE_LARGA_Y_SEGURA_DE_AL_MENOS_32_CARACTERES
JWT_EXPIRATION_MINUTES=60

# ============= SMTP (Google) =============
# Para Gmail use una "App Password": https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_STARTTLS=true
SMTP_FROM_ADDRESS=no-reply@example.com
SMTP_FROM_NAME='Sistema Académico Cayzedo'
SMTP_USERNAME=your-gmail-address@gmail.com
SMTP_PASSWORD=your-app-password

# ============= Configuración de la API =============
ASPNETCORE_ENVIRONMENT=Development
HTTP_PORT=8080
ENABLE_SWAGGER=true
ENABLE_SENSITIVE_DATA_LOGGING=false

# ============= CORS =============
# Lista separada por punto y coma. Use * para permitir cualquiera (solo en dev).
CORS_ALLOWED_ORIGINS=*

# ============= Bootstrap del primer Director =============
# Al levantar la API, si la BD no tiene ningún Director y estas variables
# están definidas, se crea el primer Director automáticamente.
# Una vez creado, este bloque ya no tiene efecto (idempotente).
BOOTSTRAP_DIRECTOR_NOMBRE='Director Inicial'
BOOTSTRAP_DIRECTOR_CEDULA=1000000000
BOOTSTRAP_DIRECTOR_CORREO=director@cayzedo.edu
BOOTSTRAP_DIRECTOR_PASSWORD=CambiarEstoYa123
