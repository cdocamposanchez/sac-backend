          "request": { "method": "GET", "url": "{{baseUrl}}/cursos/1" }
        },
        {
          "name": "Actualizar Curso",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Matemáticas 6-1\",\n  \"gradoId\": 1,\n  \"materiaId\": 1,\n  \"docenteId\": 1\n}" },
