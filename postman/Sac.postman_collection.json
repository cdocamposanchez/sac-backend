        {
          "name": "Actualizar Estudiante",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nombreCompleto\": \"Juan Estudiante Pérez\",\n  \"correo\": \"juan.estudiante@colegio.edu\"\n}" },
            "url": "{{baseUrl}}/estudiantes/1"
