    {
      "name": "Actividades",
      "description": "HU-08 / RF-07, RF-08 — Crear y gestionar actividades. Cada actividad tiene un porcentaje (1-100%) y la suma de porcentajes de las actividades activas del curso no puede superar 100%.\n\n**Esta carpeta usa DOCENTE_TOKEN.**",
      "auth": {
        "type": "bearer",
        "bearer": [{ "key": "token", "value": "{{DOCENTE_TOKEN}}", "type": "string" }]
      },
      "item": [
        {
          "name": "Crear Actividad",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Quiz Inicial\",\n  \"descripcion\": \"Diagnóstico semana 1\",\n  \"cursoId\": 1,\n  \"periodoId\": 1,\n  \"porcentaje\": 30\n}" },
            "url": "{{baseUrl}}/actividades"
          }
        },
        {
          "name": "Listar Actividades del Curso",
          "request": { "method": "GET", "url": "{{baseUrl}}/actividades?cursoId=1" }
        },
        {
          "name": "Listar Actividades del Periodo",
          "request": { "method": "GET", "url": "{{baseUrl}}/actividades?cursoId=1&periodoId=1" }
        },
        {
          "name": "Obtener Actividad por ID",
          "request": { "method": "GET", "url": "{{baseUrl}}/actividades/1" }
        },
        {
          "name": "Actualizar Actividad",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Quiz Inicial Reformulado\",\n  \"descripcion\": \"Diagnóstico semana 1 - versión revisada\",\n  \"porcentaje\": 25\n}" },
            "url": "{{baseUrl}}/actividades/1"
          }
        },
        {
          "name": "Eliminar Actividad",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/actividades/1" }
        }
      ]
    },
    {
