    {
      "name": "Cursos",
      "description": "HU-06, HU-07, HU-10 / RF-04, RF-05 — Cursos, asignaciones y cierre.",
      "item": [
        {
          "name": "Crear Curso",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Matemáticas 6-1 (2026)\",\n  \"gradoId\": 1,\n  \"materiaId\": 1,\n  \"docenteId\": 1,\n  \"anioAcademico\": 2026\n}" },
            "url": "{{baseUrl}}/cursos"
          }
        },
        {
          "name": "Listar Cursos",
          "request": { "method": "GET", "url": "{{baseUrl}}/cursos?pageIndex=0&pageSize=20" }
        },
        {
